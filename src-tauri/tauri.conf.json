{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Skills-Manager-Plus",
  "version": "1.20.1",
  "identifier": "com.agentskills.skillsmanagerplus",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skills-Manager-Plus",
        "width": 1440,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob: https:; font-src 'self' data:; connect-src ipc: http://ipc.localhost https:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNjdGOUE3MjAwQ0E5QTkKUldTcHFRd2dwL2xucmpnc1FVUWhCS0RNZjUvdmVmeG5LNnA3NDliMDUvbGd2UGZWMjFqdEpEaG4K",
      "endpoints": [
        "https://github.com/arch3rPro/Skills-Manager-Plus/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
